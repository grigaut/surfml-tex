\ProvidesPackage{macros}
\RequirePackage{xcolor}
\RequirePackage{xparse}
\RequirePackage{xspace}
\RequirePackage{amsmath}
\RequirePackage{unicode-math}

% Derivatives ---------------------------------------------
\NewDocumentCommand{\Dt}{s g}{%
  \def\tsymbol{t}
  \IfBooleanTF{#1}{%
    \ensuremath{\mathrm{D}_{\tsymbol}\IfValueT{#2}{#2}}%
  }{%
    \ensuremath{\frac{\mathrm{D}\IfValueT{#2}{#2}}{\mathrm{D}{\tsymbol}}}%
  }%
}

\NewDocumentCommand{\pdv}{s m g}{%
    \IfBooleanTF{#1}
    { % starred: partial with subscript
        \IfNoValueTF{#3}
        {\ensuremath{\partial_{{#2}}}} % \partial_{#2}
        {\ensuremath{\partial_{{#2}} #3}}  % \partial_{#2} something
    }
    { % unstarred: fraction
        \IfNoValueTF{#3}
        {\ensuremath{\frac{\partial}{\partial {#2}}}}  % \partial_{#2}
        {\ensuremath{\frac{\partial #3}{\partial {#2}}}} % \partial_{#2} something
    }%
}

\NewDocumentCommand{\pdvt}{s g}{%
    % Partial derivative with respect to time
    \IfBooleanTF{#1}
        {\pdv*{t}{#2}}
        {\pdv{t}{#2}}%
}

\NewDocumentCommand{\pdvx}{s g}{%
    % Partial derivative with respect to x
    \IfBooleanTF{#1}
        {\pdv*{x}{#2}}
        {\pdv{x}{#2}}%
}

\NewDocumentCommand{\pdvy}{s g}{%
    % Partial derivative with respect to y
    \IfBooleanTF{#1}
        {\pdv*{y}{#2}}
        {\pdv{y}{#2}}%
}

% Operators -----------------------------------------------

\NewDocumentCommand{\lap}{}{%
    \ensuremath{\mathop{\Delta}}%
}
\NewDocumentCommand{\curl}{}{%
    \ensuremath{\grad \times}%
}
\NewDocumentCommand{\divergence}{}{%
    \ensuremath{\grad \cdot}%
}
\NewDocumentCommand{\grad}{}{%
    \def\symbol{\symbf{\nabla}}
    \ensuremath{\mathop{\symbol}\nolimits}%
}
\NewDocumentCommand{\gradh}{}{%
    \def\symbol{\symbf{\nabla}_H}
    \ensuremath{\mathop{\symbol}\nolimits}%
}
\NewDocumentCommand{\gradperp}{}{%
    \def\symbol{\symbf{\nabla}^{\perp}}
    \ensuremath{\mathop{\symbol}\nolimits}%
}
\NewDocumentCommand{\gradhperp}{}{%
    \def\symbol{\symbf{\nabla}^{\perp}_H}
    \ensuremath{\mathop{\symbol}\nolimits}%
}


\NewDocumentCommand{\vect}{m}{%
  \ensuremath{\underline{\smash{#1}}}
}
\NewDocumentCommand{\mat}{m}{%
  \ifcat\noexpand#1\relax
    #1%
  \else
    \mathsf{#1}%
  \fi
}

\NewDocumentCommand{\transpose}{m}{%
  \ensuremath{{#1}^{\intercal}}
}

\NewDocumentCommand{\loss}{g}{%
    \def\symbol{\mathcal{J}}
    \IfNoValueTF{#1}
    {\ensuremath{\symbol}}
    {\ensuremath{\symbol_{\mathrm{#1}}}}
}

