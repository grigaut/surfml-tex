\ProvidesPackage{symbols}
\RequirePackage{xparse}
\RequirePackage{xstring}
\RequirePackage{amsmath}
\RequirePackage{macros}

\RenewDocumentCommand{\sf}{}{%
    \def\symbol{\psi}%
    \ensuremath{\symbol}%
}
\NewDocumentCommand{\pv}{}{%
    \def\symbol{q}%
    \ensuremath{\symbol}%
}
\NewDocumentCommand{\dt}{}{%
    \def\symbol{\mathrm{d}t}%
    \ensuremath{\symbol}%
}
\NewDocumentCommand{\dx}{}{%
    \def\symbol{\mathrm{d}x}%
    \ensuremath{\symbol}%
}
\NewDocumentCommand{\dy}{}{%
    \def\symbol{\mathrm{d}y}%
    \ensuremath{\symbol}%
}